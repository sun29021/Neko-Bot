  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "minecraft-data": "^3.103.0",
    "mineflayer": "^4.34.0",
    "mineflayer-pathfinder": "^2.1.1",
    "mineflayer-collectblock": "^1.4.1",
    "mineflayer-auto-eat": "^3.3.6",
    "groq-sdk": "^0.3.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "eslint": "^8.50.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/neko-bot"
  }
