{
  "name": "neko-minecraft-bot",
  "version": "3.0.0",
  "description": "NEKO - Intelligent, learning Minecraft bot with personality. Auto-progresses from wood to Ender Dragon.",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
